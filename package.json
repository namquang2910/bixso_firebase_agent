{
  "name": "courseai-agent",
  "version": "1.0.0",
  "description": "AI agent for a Coursera-like learning platform — powered by Firestore + Genkit + Ollama",
  "type": "module",
  "scripts": {
    "seed": "tsx scripts/seed-firestore.ts",
    "start": "tsx src/index.ts",
    "api": "tsx src/server.ts",
    "api:dev": "tsx watch src/server.ts",
    "build": "tsc",
    "genkit:ui": "genkit start -- tsx src/index.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.0.0",
    "genkit": "^0.9.0",
    "genkitx-ollama": "^0.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "genkit-cli": "^0.9.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}